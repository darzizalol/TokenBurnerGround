# list_ops.cin: list/map literals, indexing, and len()
let numbers = [10, 20, 30, 40];
print(numbers);
print(len(numbers));

numbers[1] = 99;
print(numbers[1]);

let total = 0;
let i = 0;
while (i < len(numbers)) {
    total = total + numbers[i];
    i = i + 1;
}
print(total);

let person = {"name": "Ada", "age": 36};
print(person["name"]);
print(person["age"]);

person["age"] = 37;
print(person["age"]);

print(type(numbers));
print(type(person));
